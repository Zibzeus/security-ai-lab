API_KEY=replace-with-a-long-random-value
APPROVAL_KEY=replace-with-a-different-long-random-value
LLM_BASE_URL=http://llama:8080/v1
LLM_API_KEY=local
LLM_MODEL=local-model
LLM_TIMEOUT_SECONDS=900
LLM_DISABLE_THINKING=true
# Keep JSON planning deterministic; allow thinking only for final reports.
LLM_PLAN_DISABLE_THINKING=true
LLM_REPORT_DISABLE_THINKING=false
LLM_PLAN_MAX_TOKENS=700
LLM_REPORT_MAX_TOKENS=1400
MAX_TOOL_ROUNDS=3
LLM_CONTEXT_SIZE=4096
LLM_BATCH_SIZE=64
LLAMA_THREADS=3
LLAMA_MEMORY_LIMIT=5500m
LLAMA_CPUS=3
AGENT_MEMORY_LIMIT=768m
AGENT_CPUS=1
# Pin this to a tested tag or digest after the first successful deployment.
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server
DATA_DIR=/data
POLICY_FILE=/app/policies/default.yaml
SKILL_DIR=/app/skills
KNOWLEDGE_DIRS=/app/knowledge,/app/docs,/app/rag-sources
RAG_CHUNK_CHARS=1800
RAG_OVERLAP_CHARS=200
RAG_MAX_DOCUMENTS=500
RAG_MAX_FILE_BYTES=26214400
LAB_CIDRS=10.100.31.0/24,10.10.0.0/16
BAS_EXECUTOR_URL=http://10.100.31.5:8010
BAS_EXECUTOR_SECRET=replace-with-a-second-long-random-value
MCP_CONFIG_FILE=/app/connectors/mcp.yaml
EXTRAHOP_MCP_TOKEN=
CROWDSTRIKE_MCP_TOKEN=
WEB_USERNAME=admin
# Generate with: docker compose run --rm --no-deps agent python /app/scripts/hash_web_password.py
WEB_PASSWORD_HASH=
# Generate with: openssl rand -hex 32
WEB_SESSION_SECRET=
WEB_SESSION_TTL_SECONDS=28800
WEB_MEMORY_TURNS=8
WEB_MEMORY_CHARS_PER_TURN=1200
WEB_SECURE_COOKIE=true
ENABLE_API_DOCS=false
